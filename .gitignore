# ── Node / npm ───────────────────────────────────────────
**/node_modules/
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*
# Keep package-lock.json / yarn.lock in git for reproducible installs

# ── Next.js / bundlers ─────────────────────────────────────
**/.next/
**/out/
**/build/
**/dist/

# ── Environment (never commit secrets) ───────────────────
**/.env
**/.env.local
**/.env.production
**/.env.development
**/.env.test
**/.env*.local
**/env.template.local

# ── Vercel ────────────────────────────────────────────────
**/.vercel/

# ── TypeScript / tooling cache ────────────────────────────
**/*.tsbuildinfo
# next-env.d.ts is generated but usually committed per app — do not ignore globally

# ── Logs ──────────────────────────────────────────────────
**/logs/
**/*.log

# ── Tests / coverage ──────────────────────────────────────
**/coverage/
**/.nyc_output/

# ── OS / Editor ───────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo
*~

# ── Caches ────────────────────────────────────────────────
.cache/
.parcel-cache/
.turbo/

# ── Keys / archives ────────────────────────────────────────
*.pem
*.p12
*.key
*.zip
*.tar.gz

# ── Cursor (local IDE; may contain tokens) ────────────────
.cursor/
