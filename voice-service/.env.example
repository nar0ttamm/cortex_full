# cortex_voice service environment variables
# Copy to .env on your GCP VPS

# Server
PORT=5000

# Database (same Supabase DB as backend). Use Supabase Session pooler URI on IPv4-only VMs.
# Prefer ?sslmode=verify-full so node-postgres/pg-connection-string does not warn about sslmode=require.
DATABASE_URL=postgresql://...

# AI APIs (see MANUAL_SETUP.md for vendor dashboards)
DEEPGRAM_API_KEY=
GEMINI_API_KEY=

# Deepgram live tuning (barge-in vs stability)
# DEEPGRAM_MODEL=nova-2
# DEEPGRAM_LANGUAGE=en-IN
# DEEPGRAM_ENDPOINTING_MS=260
# DEEPGRAM_UTTERANCE_END_MS=900

# TTS: Phase D default is ElevenLabs (Indian/neutral voice). Falls back to Deepgram Aura if key missing.
TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_turbo_v2_5
ELEVENLABS_OUTPUT_FORMAT=pcm_16000
# ELEVENLABS_STABILITY=0.45
# ELEVENLABS_SIMILARITY=0.8
# ELEVENLABS_STYLE=0.35
# ELEVENLABS_SPEAKER_BOOST=1
# ELEVENLABS_STREAM_LATENCY=3

# Legacy TTS (TTS_PROVIDER=deepgram|google)
# TTS_PROVIDER=deepgram
# Only if TTS_PROVIDER=google:
GOOGLE_TTS_API_KEY=

# Deepgram live audio must match FreeSWITCH fork (mono@16000h → 16000)
DEEPGRAM_SAMPLE_RATE=16000

# Realtime AI loop after CHANNEL_ANSWER (set false to only park)
VOICE_REALTIME_PIPELINE=true
# Drop forked audio during TTS + brief tail (ms) so callee-side echo does not loop STT→LLM→TTS
# VOICE_STT_POST_TTS_MS=700
# Ignore duplicate Deepgram finals within this window (ms)
# VOICE_STT_DEDUPE_MS=2800

# Optional: live session state (falls back to in-memory if unset)
# REDIS_URL=redis://127.0.0.1:6379

# FreeSWITCH ESL connection (on same VPS)
FREESWITCH_HOST=127.0.0.1
FREESWITCH_ESL_PORT=8021
FREESWITCH_ESL_PASSWORD=ClueCon

# Outbound SIP (Telnyx) — required for real calls (ESL originate)
USE_ESL_ORIGINATE=true
SIP_GATEWAY_NAME=telnyx
SIP_CALLER_ID_E164=+14355009976

# After answer: default playback(silence_stream://-1) keeps RTP in a conversational state (not parked).
# Revert with: FREESWITCH_ORIGINATE_APP=park()
# FREESWITCH_ORIGINATE_APP=playback(silence_stream://-1)
# FREESWITCH_ORIGINATE_EXTRA_VARS=ignore_early_media=true

# Dev only: set USE_ESL_ORIGINATE=false to run the stub AI pipeline without dialing

# Shared secret between backend and voice service
VOICE_SECRET=generate-a-strong-random-secret-here

# Phase D Step 1 — FreeSWITCH mod_audio_fork → WebSocket (optional overrides)
# If unset, ingress auth falls back to VOICE_SECRET.
# AUDIO_INGRESS_SECRET=
# URL FreeSWITCH must dial for audio fork (reachable from FS). Default: ws://127.0.0.1:PORT
# Use wss:// behind nginx if FS connects to public host.
# AUDIO_INGRESS_WS_BASE=ws://127.0.0.1:5000

# Backend URL (to notify on call completion)
BACKEND_URL=https://cortex-backend-api.vercel.app
