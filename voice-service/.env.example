# cortex_voice service environment variables
# Copy to .env on your GCP VPS

# Server
PORT=5000

# Database (same Supabase DB as backend)
DATABASE_URL=postgresql://...

# AI APIs
DEEPGRAM_API_KEY=
# TTS voice when TTS_PROVIDER=deepgram (Aura-2). https://developers.deepgram.com/docs/tts-models
DEEPGRAM_TTS_MODEL=aura-2-harmonia-en
# LLM: OpenAI for streaming replies and post-call JSON summary (required for live pipeline).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Must match mod_audio_fork: default fork is mono 16 kHz → use 16000 (8000 only if AUDIO_FORK_MIX=mono 8k).
# DEEPGRAM_SAMPLE_RATE=16000
# Defaults tuned for Indian English (slightly longer pause before end-of-turn).
# DEEPGRAM_ENDPOINTING_MS=300
# DEEPGRAM_UTTERANCE_END_MS=1050
# DEEPGRAM_MODEL=nova-2
# DEEPGRAM_LANGUAGE=en-IN

# Shorter greeting = faster first TTS (use {name} placeholder). Match backend VOICE_SECRET in prod.
# VOICE_SECRET=
# AUDIO_INGRESS_SECRET=   # same family; WebSocket ?token= for audio fork
# Instant first audio (8 kHz mono WAV on disk; no TTS wait). Overrides synthesized greeting.
# VOICE_GREETING_WAV=/opt/cortexflow/audio/greeting.wav
# VOICE_GREETING_TEMPLATE=Hi {name}, CortexFlow here — got a minute?
# Disk cache + startup warmup still speed up templated greetings when WAV not set.
# After sign-off when user says thanks/bye (or model wraps up): optional instant clip + hangup delay (ms)
# VOICE_SIGNOFF_WAV=
# VOICE_SIGNOFF_TEXT=Thanks, take care. Goodbye.
# VOICE_WRAP_UP_DELAY_MS=700
# VOICE_STT_POST_GREETING_MS=450

# ── Stage 3: false end-of-turn (merge short STT finals) ─────────────────
# VOICE_STT_MERGE_TAIL_MS=420
# VOICE_STT_MERGE_MAX_SHORT=28

# ── Stage 3: barge-in during TTS playback (PCM energy on audio fork) ──
# VOICE_BARGE_IN_ENABLED=true
# VOICE_BARGE_IN_RMS=1400
# VOICE_BARGE_IN_HOLD_MS=110
# VOICE_BARGE_IN_SAMPLE_RATE=16000   # override if AUDIO_FORK_MIX is 8 kHz

# TTS: deepgram | google | elevenlabs  (default deepgram = Deepgram Aura, NOT your ElevenLabs voice)
TTS_PROVIDER=deepgram
# GOOGLE_TTS_API_KEY=   # if TTS_PROVIDER=google

# ElevenLabs — required ONLY when TTS_PROVIDER=elevenlabs (setting ELEVENLABS_VOICE_ID alone does nothing)
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL=eleven_turbo_v2_5
# For richer / less “flat” speech at higher latency try: eleven_multilingual_v2
# ELEVENLABS_OUTPUT_FORMAT=pcm_16000
# 0–4; lower = better quality (default 1; old default 3 was more “compressed” sounding)
# ELEVENLABS_STREAM_LATENCY=1
# Natural preset (stability/similarity) — set false to let ElevenLabs use API defaults only
# ELEVENLABS_NATURAL_PRESET=true
# Optional overrides: ELEVENLABS_STABILITY= ELEVENLABS_SIMILARITY= ELEVENLABS_STYLE= ELEVENLABS_SPEAKER_BOOST=

# FreeSWITCH ESL connection (on same VPS)
FREESWITCH_HOST=127.0.0.1
FREESWITCH_ESL_PORT=8021
FREESWITCH_ESL_PASSWORD=ClueCon

# Outbound SIP (Telnyx) — required for real calls (ESL originate)
USE_ESL_ORIGINATE=true
# Must match gateway name in FreeSWITCH (`sofia status gateway`, e.g. external::telnyx → name is telnyx)
SIP_GATEWAY_NAME=telnyx
# Optional: override dial string if your FS image needs a different format. Placeholders: {gateway} {destination} {caller} {uuid}
# SIP_OUTBOUND_DIAL_TEMPLATE=sofia/gateway/{gateway}/{destination}
SIP_CALLER_ID_E164=+14355009976

# WebSocket audio ingress: if uuid_audio_fork returns "-ERR no reply", try quoting fix in code first;
# or set AUDIO_INGRESS_REQUIRE_TOKEN=false to omit ?token= (only if port 5000 is not public).
# AUDIO_INGRESS_REQUIRE_TOKEN=true

# TTS playback files: Node writes WAVs here; FreeSWITCH uuid_broadcast opens the same path ON THE FS HOST.
# If FS runs in Docker, host /tmp is NOT the container /tmp — set a shared dir and bind-mount it into FS, e.g.:
#   mkdir -p /opt/cortexflow/shared-tts
#   VOICE_TTS_TMP_DIR=/opt/cortexflow/shared-tts
#   docker run ... -v /opt/cortexflow/shared-tts:/opt/cortexflow/shared-tts ...
# VOICE_TTS_TMP_DIR=/opt/cortexflow/shared-tts

# mod_audio_fork (drachtio): use "mono 8k" or "mono 16k" — NOT "mono@16000h" (wrong API shape).
# AUDIO_FORK_MIX=mono 16k

# TTS: set elevenlabs only if ELEVENLABS_* are set; was previously ignored → fell back to Deepgram.
# UUID_BROADCAST_LEG: outbound PSTN often needs both legs — default both (was aleg-only, can sound silent).
# UUID_BROADCAST_LEG=both

# ESL: if FreeSWITCH starts after Node (Docker boot order), hooks retry until ESL is up
# VOICE_ESL_RETRY_MS=5000
# VOICE_ESL_RETRY_MAX=60
# Debug: log sofia dial string on each originate
# VOICE_LOG_ORIGINATE=true

# Dev only: set USE_ESL_ORIGINATE=false to run the stub AI pipeline without dialing

# Shared secret between backend and voice service
VOICE_SECRET=generate-a-strong-random-secret-here

# Backend URL (to notify on call completion)
BACKEND_URL=https://cortex-backend-api.vercel.app
