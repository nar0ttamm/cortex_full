# ============================================================
# Backend API — Environment Variables
# Copy to .env for local development
# Set all in Vercel dashboard for production
# ============================================================

# ── Database ──────────────────────────────────────────────
# Supabase → Project Settings → Database → Connection String (Session mode)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# ── Encryption ────────────────────────────────────────────
# AES-256 key for stored credentials (64-character hex)
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# ── Server ────────────────────────────────────────────────
PORT=4000

# ── Calling ───────────────────────────────────────────────
# simulated = local dev / pre-Exotel KYC mode
# live      = real Exotel calls (requires Exotel credentials in DB)
CALLING_MODE=simulated

# Delay between lead ingest and first AI call (seconds)
CALL_DELAY_SECONDS=120

# Public URL of this backend (used in Exotel callback URLs)
# Set to your Vercel deployment URL in production
BACKEND_URL=http://localhost:4000

# ── Notifications ─────────────────────────────────────────
# Admin contact details for new lead alerts
ADMIN_EMAIL=cortexflowagent@gmail.com
ADMIN_PHONE=+917021433461

# ── Security ──────────────────────────────────────────────
# Protects /v1/admin/* routes — optional in dev, required in production
ADMIN_TOKEN=

# Vercel Cron Secret — Vercel sets this automatically
# Do NOT set manually; Vercel passes it in Authorization header
# CRON_SECRET=  (set in Vercel dashboard only)

# ── Default Tenant ────────────────────────────────────────
# Used in single-tenant dev mode and fallback lookups
DEFAULT_TENANT_ID=b50750c7-0a91-4cd4-80fa-8921f974a8ec

# ── cortex_voice (GCP VM) ─────────────────────────────────
# Vercel must reach the VM on TCP 5000 when IP changes, update and redeploy.
VOICE_SERVICE_URL=http://YOUR_VM_IP:5000
# Same value on cortex_voice VM (.env). Generate once: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VOICE_SECRET=
# When LLM returns naive ISO without offset, backend assumes IST (+05:30). Clock skew / webhook retries (ms).
APPOINTMENT_ISO_PAST_GRACE_MS=120000
